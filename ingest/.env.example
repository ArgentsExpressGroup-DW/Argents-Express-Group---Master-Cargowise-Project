# ─────────────────────────────────────────────────────────────
# Argents Supabase Ingest Job — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# ── Microsoft Graph / Azure AD ────────────────────────────────
# App registration in the Argents Azure tenant.
# Required permissions: Sites.Read.All (or Files.Read.All)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── SharePoint site where CargoWise files land ────────────────
# The site hostname.
SHAREPOINT_HOST=argentsexpress.sharepoint.com
# The site path.
SHAREPOINT_SITE_PATH=/sites/DashboardsReports
# The drive/document library name. "Documents" is the Graph API name
# for the default "Shared Documents" library.
SHAREPOINT_DRIVE_NAME=Documents
# Folder path within the drive where CargoWise reports land.
SHAREPOINT_REPORTS_FOLDER=/Administration/Supabase Migration Project/Cargowise Daily File Dumps

# ── Supabase ──────────────────────────────────────────────────
# Use the service-role key (bypasses RLS) for the ingest job.
# Keep this secret — it has full DB write access.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Ingest behaviour ─────────────────────────────────────────
# Log level: debug | info | warn | error
LOG_LEVEL=info
# Dry-run mode: set to 'true' to parse and log without writing to Supabase
DRY_RUN=false
